generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Student {
  id            Int          @id @default(autoincrement())
  first_name    String
  last_name     String
  middle_name   String
  date_of_birth DateTime
  address       String
  gender        GenderEnum
  email         String
  created_at    DateTime     @default(now())
  enrollments   Enrollment[]
}

enum GenderEnum {
  male
  female
}

model Enrollment {
  id            Int              @id @default(autoincrement())
  student       Student          @relation(fields: [student_id], references: [id])
  student_id    Int
  curriculum    Curriculum       @relation(fields: [curriculum_id], references: [id])
  curriculum_id Int
  school_year   String // e.g., "2025-2026"
  status        EnrollmentStatus @default(pending)

  // These store the calculation at the MOMENT of enrollment
  total_tuition_snapshot Decimal @db.Decimal(10, 2)
  total_misc_snapshot    Decimal @db.Decimal(10, 2)

  payments   TuitionFeePayment[]
  created_at DateTime            @default(now())
}

model TuitionFeePayment {
  id             Int        @id @default(autoincrement())
  enrollment     Enrollment @relation(fields: [enrollment_id], references: [id])
  enrollment_id  Int
  amount_paid    Decimal    @db.Decimal(10, 2)
  payment_date   DateTime   @default(now())
  receipt_no     String     @unique
  payment_method String // e.g., "Cash", "GCash"
}

enum EnrollmentStatus {
  pending
  partially_paid
  fully_paid
  dropped
}

model Subject {
  id                  Int                  @id @default(autoincrement())
  subject_code        String               @unique
  subject_name        String
  created_at          DateTime             @default(now())
  inactive            Boolean              @default(false)
  prices              SubjectPrice[]
  curriculum_subjects CurriculumSubjects[]

  @@fulltext([subject_code, subject_name(order: Desc)])
}

model SubjectPrice {
  id                 Int                  @id @default(autoincrement())
  subject            Subject              @relation(fields: [subject_code], references: [subject_code])
  subject_code       String
  price              Decimal              @db.Decimal(10, 2)
  created_at         DateTime             @default(now())
  curriculumSubjects CurriculumSubjects[]
}

model Curriculum {
  id                  Int                  @id @default(autoincrement())
  grade_level         GradeLevelEnum
  curriculum_code     String               @unique
  curriculum_name     String
  created_at          DateTime             @default(now())
  miscellaneous_fee   Decimal              @db.Decimal(10, 2)
  curriculum_subjects CurriculumSubjects[]
  inactive            Boolean              @default(false)
  enrollments         Enrollment[]
  grade1_settings     EnrollmentSettings[]  @relation("Grade1Curriculum")
  grade2_settings     EnrollmentSettings[]  @relation("Grade2Curriculum")
  grade3_settings     EnrollmentSettings[]  @relation("Grade3Curriculum")
  grade4_settings     EnrollmentSettings[]  @relation("Grade4Curriculum")
  grade5_settings     EnrollmentSettings[]  @relation("Grade5Curriculum")
  grade6_settings     EnrollmentSettings[]  @relation("Grade6Curriculum")

  @@fulltext([curriculum_code, curriculum_name(order: Desc)])
}

model CurriculumSubjects {
  curriculum       Curriculum   @relation(fields: [curriculum_id], references: [id])
  curriculum_id    Int
  subject          Subject      @relation(fields: [subject_id], references: [id])
  subject_id       Int
  subject_price    SubjectPrice @relation(fields: [subject_price_id], references: [id])
  subject_price_id Int

  created_at DateTime @default(now())

  @@id([curriculum_id, subject_id])
}

enum QuarterEnum {
  firstQuarter
  secondQuarter
  thirdQuarter
  fourthQuarter
}

enum GradeLevelEnum {
  grade1
  grade2
  grade3
  grade4
  grade5
  grade6
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  email         String   @unique
  hash_password String
  role          Role[]
  created_at    DateTime @default(now())
}

enum Roles {
  registrar
  cashier
  admin
}

model Role {
  user       User     @relation(fields: [user_id], references: [id])
  user_id    Int
  role       Roles
  created_at DateTime @default(now())

  @@id([user_id, role])
}

model EnrollmentSettings {
  id                              Int         @id @default(autoincrement())
  grade1_curriculum              Curriculum? @relation("Grade1Curriculum", fields: [grade1_curriculum_id], references: [id])
  grade1_curriculum_id            Int?
  grade2_curriculum              Curriculum? @relation("Grade2Curriculum", fields: [grade2_curriculum_id], references: [id])
  grade2_curriculum_id            Int?
  grade3_curriculum              Curriculum? @relation("Grade3Curriculum", fields: [grade3_curriculum_id], references: [id])
  grade3_curriculum_id            Int?
  grade4_curriculum              Curriculum? @relation("Grade4Curriculum", fields: [grade4_curriculum_id], references: [id])
  grade4_curriculum_id            Int?
  grade5_curriculum              Curriculum? @relation("Grade5Curriculum", fields: [grade5_curriculum_id], references: [id])
  grade5_curriculum_id            Int?
  grade6_curriculum              Curriculum? @relation("Grade6Curriculum", fields: [grade6_curriculum_id], references: [id])
  grade6_curriculum_id            Int?
  is_online_enrollment_enabled    Boolean     @default(false)
  created_at                      DateTime    @default(now())
  updated_at                      DateTime    @updatedAt
}
