generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Student {
  student_id    Int        @id @default(autoincrement())
  first_name    String
  last_name     String
  middle_name   String
  date_of_birth DateTime
  address       String
  gender        GenderEnum
  email         String
  created_at    DateTime   @default(now())
}

enum GenderEnum {
  male
  female
}

model Subject {
  id                  Int                  @id @default(autoincrement())
  subject_code        String               @unique
  subject_name        String
  created_at          DateTime             @default(now())
  inactive            Boolean              @default(false)
  prices              SubjectPrice[]
  curriculum_subjects CurriculumSubjects[]

  @@fulltext([subject_code, subject_name(order: Desc)])
}

model SubjectPrice {
  id                 Int                  @id @default(autoincrement())
  subject            Subject              @relation(fields: [subject_code], references: [subject_code])
  subject_code       String
  price              Decimal              @db.Decimal(10, 2)
  created_at         DateTime             @default(now())
  curriculumSubjects CurriculumSubjects[]
}

model Curriculum {
  id                  Int                  @id @default(autoincrement())
  grade_level         GradeLevelEnum
  curriculum_code     String               @unique
  curriculum_name     String
  created_at          DateTime             @default(now())
  miscellaneous_fee   Decimal              @db.Decimal(10, 2)
  curriculum_subjects CurriculumSubjects[]

  @@fulltext([curriculum_code, curriculum_name(order: Desc)])
}

model CurriculumSubjects {
  curriculum       Curriculum   @relation(fields: [curriculum_id], references: [id])
  curriculum_id    Int
  subject          Subject      @relation(fields: [subject_id], references: [id])
  subject_id       Int
  subject_price    SubjectPrice @relation(fields: [subject_price_id], references: [id])
  subject_price_id Int

  created_at DateTime @default(now())

  @@id([curriculum_id, subject_id])
}

enum QuarterEnum {
  firstQuarter
  secondQuarter
  thirdQuarter
  fourthQuarter
}

enum GradeLevelEnum {
  grade1
  grade2
  grade3
  grade4
  grade5
  grade6
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  email         String   @unique
  hash_password String
  role          Role[]
  created_at    DateTime @default(now())
}

enum Roles {
  registrar
  cashier
  admin
}

model Role {
  user       User     @relation(fields: [user_id], references: [id])
  user_id    Int
  role       Roles    @unique
  created_at DateTime @default(now())
}
