generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Student {
  id            Int          @id
  first_name    String
  last_name     String
  middle_name   String
  date_of_birth DateTime
  address       String
  gender        GenderEnum
  email         String
  created_at    DateTime     @default(now())
  enrollments   Enrollment[]
}

model PreEnrollment {
  id            Int                 @id @default(autoincrement())
  reference_code String?           @unique
  first_name    String
  last_name     String
  middle_name   String
  date_of_birth DateTime
  address       String
  gender        GenderEnum
  email         String
  grade_level   GradeLevelEnum
  school_year   String
  status        PreEnrollmentStatus @default(pending)
  created_at    DateTime            @default(now())
}

enum GenderEnum {
  male
  female
}

model Enrollment {
  id             Int              @id @default(autoincrement())
  reference_code String           @unique
  student        Student          @relation(fields: [student_id], references: [id])
  student_id     Int
  curriculum     Curriculum       @relation(fields: [curriculum_id], references: [id])
  curriculum_id  Int
  school_year    String
  status         EnrollmentStatus @default(approved)

  // These store the calculation at the MOMENT of enrollment
  total_tuition_snapshot Decimal @db.Decimal(10, 2)
  total_misc_snapshot    Decimal @db.Decimal(10, 2)

  // Optional override for minimum partial payment. If null, defaults to 20% of total tuition.
  min_partial_payment_override Decimal? @db.Decimal(10, 2)

  payments   TuitionFeePayment[]
  created_at DateTime            @default(now())
}

model TuitionFeePayment {
  id                Int               @id @default(autoincrement())
  enrollment        Enrollment        @relation(fields: [enrollment_id], references: [id])
  enrollment_id     Int
  amount_paid       Decimal           @db.Decimal(10, 2)
  payment_date      DateTime          @default(now())
  receipt_no        String            @unique
  rollback_requests RollbackRequest[]
}

enum PreEnrollmentStatus {
  pending
  approved
  declined
}

enum EnrollmentStatus {
  approved
  dropped
  declined
}

enum RollbackStatus {
  pending
  approved
  denied
  cancelled
}

model Subject {
  id                  Int                  @id @default(autoincrement())
  subject_code        String               @unique
  subject_name        String
  created_at          DateTime             @default(now())
  inactive            Boolean              @default(false)
  prices              SubjectPrice[]
  curriculum_subjects CurriculumSubjects[]
}

model SubjectPrice {
  id                 Int                  @id @default(autoincrement())
  subject            Subject              @relation(fields: [subject_id], references: [id])
  subject_id         Int
  price              Decimal              @db.Decimal(10, 2)
  created_at         DateTime             @default(now())
  curriculumSubjects CurriculumSubjects[]
}

model Curriculum {
  id                        Int                      @id @default(autoincrement())
  grade_level               GradeLevelEnum
  curriculum_code           String                   @unique
  curriculum_name           String
  created_at                DateTime                 @default(now())
  miscellaneous_fee         Decimal                  @db.Decimal(10, 2)
  curriculum_subjects       CurriculumSubjects[]
  inactive                  Boolean                  @default(false)
  enrollments               Enrollment[]
  grade_curriculum_settings GradeCurriculumSetting[]
}

model CurriculumSubjects {
  curriculum       Curriculum   @relation(fields: [curriculum_id], references: [id])
  curriculum_id    Int
  subject          Subject      @relation(fields: [subject_id], references: [id])
  subject_id       Int
  subject_price    SubjectPrice @relation(fields: [subject_price_id], references: [id])
  subject_price_id Int

  created_at DateTime @default(now())

  @@id([curriculum_id, subject_id])
}

enum QuarterEnum {
  firstQuarter
  secondQuarter
  thirdQuarter
  fourthQuarter
}

enum GradeLevelEnum {
  grade1
  grade2
  grade3
  grade4
  grade5
  grade6
}

model User {
  id                          Int               @id
  username                    String            @unique
  email                       String            @unique
  hash_password               String
  first_name                  String
  last_name                   String
  middle_name                 String?
  gender                      GenderEnum
  birthdate                   DateTime
  role                        Role[]
  inactive                    Boolean           @default(false)
  created_at                  DateTime          @default(now())
  rollback_requests_requested RollbackRequest[] @relation("RollbackRequestedBy")
  rollback_requests_reviewed  RollbackRequest[] @relation("RollbackReviewedBy")
}

enum Roles {
  registrar
  cashier
  admin
}

model Role {
  user       User     @relation(fields: [user_id], references: [id])
  user_id    Int
  role       Roles
  created_at DateTime @default(now())

  @@id([user_id, role])
}

model GradeCurriculumSetting {
  id            Int            @id @default(autoincrement())
  school_year   String
  grade_level   GradeLevelEnum
  curriculum    Curriculum     @relation(fields: [curriculum_id], references: [id])
  curriculum_id Int

  @@unique([school_year, grade_level])
}

model EnrollmentSettings {
  id                           Int      @id @default(autoincrement())
  school_year                  String
  is_online_enrollment_enabled Boolean  @default(false)
  created_at                   DateTime @default(now())
  updated_at                   DateTime @updatedAt
}

model RollbackRequest {
  id              Int               @id @default(autoincrement())
  payment         TuitionFeePayment @relation(fields: [payment_id], references: [id])
  payment_id      Int
  requested_by    User              @relation("RollbackRequestedBy", fields: [requested_by_id], references: [id])
  requested_by_id Int
  reason          String
  status          RollbackStatus    @default(pending)
  reviewed_by     User?             @relation("RollbackReviewedBy", fields: [reviewed_by_id], references: [id])
  reviewed_by_id  Int?
  reviewed_at     DateTime?
  created_at      DateTime          @default(now())

  @@index([payment_id])
  @@index([status])
  @@index([requested_by_id])
}
